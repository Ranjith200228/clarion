# Phase 15 — environment variables docker-compose interpolates.
#
# Copy to .env (gitignored) and fill in. The container runs without
# any of these — the agent stays in scripted mode for CI / dev — but
# the Live Agent tab needs OPENAI_API_KEY to call the real LLM.

# OpenAI API key for the live agent path. Leave blank to fall back to
# guardrails-only / scripted behavior.
OPENAI_API_KEY=

# Override the default model (gpt-4o-mini) if desired.
# CLARION_MODEL=gpt-4o-mini

# Set to 1 in CI / when running the suite to skip the FastAPI module-
# level singleton (avoids OpenAIClient construction at import time).
# CLARION_SKIP_AUTOAPP=1
