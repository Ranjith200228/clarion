# --- VCS / IDE noise ---
.git/
.gitignore
.github/
.idea/
.vscode/
.editorconfig
*.swp
*~

# --- Python build artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- OS metadata ---
.DS_Store
Thumbs.db

# --- Generated per-customer artifacts ---
# These are regenerated in the builder stage by scripts/build_indices.sh.
# Shipping pre-built copies would bloat the build context with
# host-platform binaries; the builder produces fresh ones for the
# container target.
data/ophthalmology/structured.sqlite
data/ophthalmology/structured.sqlite-journal
data/ophthalmology/rules.faiss
data/ophthalmology/rules_meta.json
data/orthopedics/structured.sqlite
data/orthopedics/structured.sqlite-journal
data/orthopedics/rules.faiss
data/orthopedics/rules_meta.json
data/*/audit.jsonl
data/*/traces.jsonl

# --- Local dev reports directory (not committed) ---
reports/

# --- Local dev secrets ---
.env
.env.*
!.env.example

# --- Local docker overrides ---
docker-compose.override.yml

# --- Test temp dirs ---
/tmp/
htmlcov/
